JavaScript
document.addEventListener('DOMContentLoaded', function() {
    const startBtn = document.getElementById('start-btn');
    
    if (!startBtn) {
        console.error("시작 버튼을 찾을 수 없습니다. HTML의 id 설정을 확인하세요.");
        return;
    }

    startBtn.addEventListener('click', function() {
        // 1. 입력값 안전하게 가져오기
        const maleInput = document.getElementById('male-input');
        const femaleInput = document.getElementById('female-input');
        const colsInput = document.getElementById('cols-input');

        const maleRaw = maleInput ? maleInput.value : "";
        const femaleRaw = femaleInput ? femaleInput.value : "";
        const numCols = colsInput ? (parseInt(colsInput.value) || 6) : 6;

        // 다양한 줄바꿈(\r\n, \n) 및 쉼표, 공백을 기준으로 쪼개기
        const males = maleRaw.split(/[\n\r,]+/).map(name => name.trim()).filter(name => name.length > 0);
        const females = femaleRaw.split(/[\n\r,]+/).map(name => name.trim()).filter(name => name.length > 0);

        // 학생 통합 배열 생성
        let students = [
            ...males.map(name => ({ name, gender: 'male' })),
            ...females.map(name => ({ name, gender: 'female' }))
        ];

        // 학생이 아무도 입력되지 않았을 때 알림
        if (students.length === 0) {
            alert("남학생 또는 여학생 명단에 이름을 입력해 주세요!");
            return;
        }

        // 2. 무작위 무작위 셔플 (Fisher-Yates 알고리즘)
        for (let i = students.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            const temp = students[i];
            students[i] = students[j];
            students[j] = temp;
        }

        // 3. 화면에 배치하기
        const gridContainer = document.getElementById('classroom-grid');
        if (!gridContainer) return;

        gridContainer.innerHTML = ''; // 기존 메시지나 자리 비우기
        
        // CSS Grid 열 개수 설정
        gridContainer.style.gridTemplateColumns = `repeat(${numCols}, 1fr)`;

        // 책상 생성 및 추가
        students.forEach(student => {
            const desk = document.createElement('div');
            desk.classList.add('desk', student.gender);
            desk.innerText = student.name;
            gridContainer.appendChild(desk);
        });

        // 빈자리가 생기면 채워주기
        const remainder = students.length % numCols;
        if (remainder !== 0) {
            const emptySeatsNeeded = numCols - remainder;
            for (let i = 0; i < emptySeatsNeeded; i++) {
                const emptyDesk = document.createElement('div');
                emptyDesk.classList.add('desk', 'empty');
                emptyDesk.innerText = "빈자리";
                gridContainer.appendChild(emptyDesk);
            }
        }
    });
});
